@page "/expenses"

@inject HttpClient Http
@inject IDialogService DialogService

<MudTable Items="expenses"
          Filter="FilterExpense"
          Hover="true"
          Bordered="true"
          Striped="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Expenses</MudText>
        <MudSpacer />

        <MudTextField @bind-Value="searchText"
                      Placeholder="Search..."
                      Immediate="true"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="me-2"
                      Margin="Margin.Dense" />
        <MudSpacer />
        <MudSelect T="int?"
                   @bind-Value="selectedBudgetId"
                   Label="Budget"
                   Clearable="true"
                   Margin="Margin.Dense"
                   Class="me-2"
                   Style="min-width:180px;">
            <MudSelectItem T="int?" Value="@(null)">All Budgets</MudSelectItem>
            @foreach (var budget in budgets)
            {
                <MudSelectItem T="int?" Value="@budget.Id">@budget.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSpacer />
        <MudButton Color="Color.Success"
                   Variant="Variant.Filled"
                   Size="Size.Small"
                   OnClick="@(() => AddBudgetAsync())">
            Add Expense
        </MudButton>
    </ToolBarContent>

    <HeaderContent>
        <MudTh>Id</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Amount</MudTh>
        <MudTh>Date</MudTh>
        <MudTh>Budget</MudTh>
        <MudTh></MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd>@context.Id</MudTd>
        <MudTd>@context.Description</MudTd>
        <MudTd>@context.Amount.ToString("C")</MudTd>
        <MudTd>@context.Date</MudTd>
        <MudTd>@GetBudgetName(context.BudgetId)</MudTd>

        <MudTd>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Outlined"
                       Size="Size.Small"
                       OnClick="@(() => EditExpenseAsync(context))">
                Edit
            </MudButton>
            <MudButton Color="Color.Error"
                       Variant="Variant.Outlined"
                       Size="Size.Small"
                       Class="ms-2"
                       OnClick="@(() => DeleteExpense(context.Id))">
                Delete
            </MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<BudgetDto> budgets = new();
    private List<ExpenseDto> expenses = new();
    private ExpenseDto newExpense = new() { Description = "New Expense", Amount = 0 };

    private string searchText = string.Empty;
    private int? selectedBudgetId;

    protected override async Task OnInitializedAsync()
    {
        await LoadBudgets();
        await LoadExpenses();
    }

    private async Task LoadBudgets()
    {
        budgets = await Http.GetFromJsonAsync<List<BudgetDto>>("budget") ?? new();
    }

    private async Task LoadExpenses()
    {
        expenses = await Http.GetFromJsonAsync<List<ExpenseDto>>("expense") ?? new();
    }

    private string GetBudgetName(int budgetId)
    {
        var budget = budgets.FirstOrDefault(b => b.Id == budgetId);
        return budget?.Name ?? "Unknown";
    }

    private bool FilterExpense(ExpenseDto expense)
    {
        if (selectedBudgetId.HasValue && expense.BudgetId != selectedBudgetId.Value)
            return false;

        if (string.IsNullOrWhiteSpace(searchText))
            return true;

        var term = searchText.Trim();

        return expense.Id.ToString().Contains(term, StringComparison.OrdinalIgnoreCase)
               || (expense.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
               || expense.Amount.ToString("0.##").Contains(term, StringComparison.OrdinalIgnoreCase)
               || expense.Date.ToString().Contains(term, StringComparison.OrdinalIgnoreCase)
               || GetBudgetName(expense.BudgetId).Contains(term, StringComparison.OrdinalIgnoreCase);
    }

    private async Task AddBudgetAsync()
    {
        var dialog = await DialogService.ShowAsync<ExpenseEditorDialog>(
            "Add Expense",
            new DialogParameters
            {
                { nameof(ExpenseEditorDialog.Model), new ExpenseDto() },
                { nameof(ExpenseEditorDialog.Budgets), budgets }
            }
        );

        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var newExpense = result.Data as ExpenseDto;
            var response = await Http.PostAsJsonAsync("expense", newExpense);
            if (response.IsSuccessStatusCode)
                await LoadExpenses();
        }
    }

    private async Task EditExpenseAsync(ExpenseDto expense)
    {
        var dialog = await DialogService.ShowAsync<ExpenseEditorDialog>(
            "Edit Expense",
            new DialogParameters
            {
                { nameof(ExpenseEditorDialog.Model), expense },
                { nameof(ExpenseEditorDialog.Budgets), budgets }
            }
        );

        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var updatedExpense = result.Data as ExpenseDto;
            var response = await Http.PutAsJsonAsync($"expense/{updatedExpense.Id}", updatedExpense);
            if (response.IsSuccessStatusCode)
                await LoadExpenses();
            else
                Console.WriteLine($"Failed to update expense: {response.ReasonPhrase}");
        }
    }

    private async Task DeleteExpense(int id)
    {
        var response = await Http.DeleteAsync($"expense/{id}");
        if (response.IsSuccessStatusCode)
            await LoadExpenses();
    }
}
